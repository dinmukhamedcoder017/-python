def check_password(password):
    score = 0
    if len(password) >= 8:
        score += 1
    if len(password) >= 12:
        score += 1
    if any(c.isupper() for c in password):
        score += 1
    if any(c.islower() for c in password):
        score += 1
    if any(c.isdigit() for c in password):
        score += 1
    specials = "!@#$%^&*"
    if any(c in specials for c in password):
        score += 1
    
    if score == 6:
        return "супер надежный"
    elif score >= 4:
        return "средний"
    else:
        return "слабый - поменяй"

print("***проверка пароля***")
while True:
    pw = input("введи пароль (или 'exit'): ")
    if pw == 'exit':
        break
    result = check_password(pw)
    print(f"сложность: {result}")
